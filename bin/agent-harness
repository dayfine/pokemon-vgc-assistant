#!/bin/sh
# agent-harness — scaffolding CLI for the Claude Code orchestration harness.
#
# Usage:
#   agent-harness init <target-dir>          Bootstrap a new project from this template.
#   agent-harness sync                       Update `harness: reusable` files from upstream.
#   agent-harness check                      Verify the layer model (delegates to agent-harness-check.sh).
#   agent-harness help                       This message.
#
# Exit code: 0 on success, 1 on any error.
#
# Status: stub. `init` and `sync` are placeholders; only `check` and
# `help` are functional. Implementation is being driven by real
# bootstrap of the second consuming project — see the agent-harness
# repo's open issues / follow-ups for current state.

set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HARNESS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
agent-harness — scaffolding CLI for the Claude Code orchestration harness.

Usage:
  agent-harness init <target-dir>      Bootstrap a new project from this template.
  agent-harness sync                   Update `harness: reusable` files from upstream.
  agent-harness check                  Verify the layer model.
  agent-harness help                   This message.

Subcommand status:
  check    — implemented (delegates to bin/agent-harness-check.sh).
  init     — implemented.
  sync     — implemented.
EOF
}

cmd_check() {
  exec sh "$SCRIPT_DIR/agent-harness-check.sh"
}

cmd_init() {
  target=${1:-}
  if [ -z "$target" ]; then
    echo "agent-harness init: missing target directory argument" >&2
    echo "usage: agent-harness init <target-dir>" >&2
    exit 1
  fi

  echo "Bootstrapping agent-harness in $target..."
  
  # 1. Create directories
  mkdir -p "$target/.agents/agents" "$target/.agents/rules" "$target/dev/lib" "$target/.github/workflows" "$target/.claude"
  
  # 2. Copy files
  cp "$HARNESS_ROOT/.agents/agents/"*.md "$target/.agents/agents/"
  cp "$HARNESS_ROOT/.agents/rules/"*.md "$target/.agents/rules/"
  cp "$HARNESS_ROOT/.github/workflows/"*.yml "$target/.github/workflows/"
  cp "$HARNESS_ROOT/dev/lib/"*.sh "$target/dev/lib/"
  cp "$HARNESS_ROOT/dev/agent-feature-workflow.md" "$target/dev/"
  cp "$HARNESS_ROOT/dev/agent-feature-workflow-example.md" "$target/dev/"
  cp "$HARNESS_ROOT/.claude/settings.json" "$target/.claude/"
  cp "$HARNESS_ROOT/.antigravityignore" "$target/"
  cp "$HARNESS_ROOT/CLAUDE.md" "$target/"
  cp -a "$HARNESS_ROOT/.geminirules" "$target/" || true
  cp -a "$HARNESS_ROOT/.cursorrules" "$target/" || true

  cat <<EOF >&2

Bootstrap complete!

Next steps:
  1. Adjust the Configuration block at the top of:
       $target/.agents/agents/lead-orchestrator.md
       $target/.github/workflows/orchestrator.yml
     Replace each project-specific literal listed in the block.
  2. Write the project authority files:
       $target/.agents/rules/qc-structural-authority.md
       $target/.agents/rules/qc-behavioral-authority.md
     (See the source-project examples for the shape.)
  3. Write any feat-* agents your project needs as
     $target/.agents/agents/feat-<name>.md (mark harness: project).
  4. Edit $target/dev/agent-feature-workflow.md for your toolchain
     (the shipped version is generic; see dev/agent-feature-workflow-example.md).
  5. Run agent-harness check to verify the layer model.
EOF
  exit 0
}

cmd_sync() {
  exec sh "$SCRIPT_DIR/agent-harness-sync.sh" "$@"
}

case "${1:-help}" in
  init)  shift; cmd_init "$@" ;;
  sync)  shift; cmd_sync "$@" ;;
  check) shift; cmd_check ;;
  help|-h|--help) usage ;;
  *)     echo "agent-harness: unknown subcommand: $1" >&2; usage; exit 1 ;;
esac
